{
  "expo": {
    "name": "Couple Buzz",
    "slug": "couple-buzz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FFF5F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.couplebuzz.app",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ]
  }
}
